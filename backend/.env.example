# x.ai API key (get from https://console.x.ai)
OPENAI_API_KEY=your-xai-api-key-here

# x.ai base URL
OPENAI_BASE_URL=https://api.x.ai/v1

# Disable OpenAI Agents SDK tracing (uses platform.openai.com which doesn't accept x.ai keys)
OPENAI_AGENTS_DISABLE_TRACING=1

# Server port
PORT=5000

# Coding CLI tool: "opencode" or "kiro-cli"
CODING_CLI=opencode
