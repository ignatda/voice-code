# ── LLM Provider Rotation ─────────────────────────────────────────
# Comma-separated provider list: first = primary, rest = fallbacks on 429
# Available: xai, gemini, groq
LLM_PROVIDERS=xai

# Provider API keys (leave empty to skip that provider)
XAI_API_KEY=your-xai-api-key-here
GEMINI_API_KEY=
GROQ_API_KEY=

# Disable OpenAI Agents SDK tracing (incompatible with non-OpenAI providers)
OPENAI_AGENTS_DISABLE_TRACING=1

# Your OpenAI API Key 
OPENAI_API_KEY=

# ── Voice ─────────────────────────────────────────────────────────
# STT/TTS provider is determined by LLM_PROVIDERS (same provider for all)
TTS_MAX_LENGTH=500

# Orchestrator type: "piped" (default STT→orchestrator→TTS) or "native" (xAI Realtime voice agent)
ORCHESTRATOR_TYPE=native

# Server port
PORT=5000

# Coding CLI tool: "opencode", "kiro-cli", or "none"
CODING_CLI=opencode

# IDE type: "jetbrains", "vscode", or "none"
IDE_TYPE=jetbrains

# Extensions: comma-separated names or "none"
EXTENSIONS=none

# Scheduled tasks: comma-separated names or "none"
SCHEDULED_TASKS=none

